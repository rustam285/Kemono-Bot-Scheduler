# Supabase (только здесь, не выносить в UI)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key   # используется бэкендом для обхода RLS

# Шифрование VK токена (сгенерировать: python -c "from services.crypto import generate_key; print(generate_key())")
ENCRYPTION_KEY=

# Bootstrap VK — используется ТОЛЬКО если settings.json ещё не существует.
# После первого сохранения настроек в UI эти значения игнорируются.
VK_TOKEN=
VK_GROUP_ID=
VK_OWNER_ID=

# Технические параметры
VK_API_VERSION=5.199
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
MAX_TEMP_SIZE_GB=3                 # макс. суммарный размер /tmp/vk_scheduler
MAX_CONCURRENT_TASKS=3             # макс. одновременных фоновых задач публикации

# Telegram MTProto (Telethon) — для отложенных постов в Telegram
# Получить api_id и api_hash: https://my.telegram.org → API development tools
TG_API_ID=0
TG_API_HASH=
# Прокси для обхода DPI (MTProto часто блокируется провайдерами)
# Формат: socks5://host:port или socks5://user:pass@host:port
TG_PROXY=
